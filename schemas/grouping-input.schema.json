{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GroupingInput",
  "type": "object",
  "required": ["grouping_strategy", "photos"],
  "properties": {
    "grouping_strategy": {
      "type": "string",
      "enum": [
        "TIME_BASED",
        "LOCATION_BASED",
        "SCENE_BASED",
        "FOOD_TYPE_BASED",
        "STORY_FLOW_BASED"
      ]
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["photo_id", "file_name"],
        "properties": {
          "photo_id": { "type": "string" },
          "file_name": { "type": "string" },
          "captured_at": { "type": ["string", "null"] },
          "has_gps": { "type": ["boolean", "null"] },
          "gps": {
            "type": ["object", "null"],
            "properties": {
              "lat": { "type": ["number", "null"] },
              "lon": { "type": ["number", "null"] }
            }
          },
          "location_hint": { "type": ["string", "null"] },
          "scene_type": { "type": ["string", "null"] },
          "summary": { "type": ["string", "null"] },
          "subjects": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
