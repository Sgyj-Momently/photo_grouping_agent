{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GroupingOutput",
  "type": "object",
  "required": ["grouping_strategy", "group_count", "groups"],
  "properties": {
    "grouping_strategy": { "type": "string" },
    "group_count": { "type": "integer" },
    "groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group_id", "photo_ids", "group_reason"],
        "properties": {
          "group_id": { "type": "string" },
          "start_time": { "type": ["string", "null"] },
          "end_time": { "type": ["string", "null"] },
          "photo_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "location_hint": { "type": ["string", "null"] },
          "group_reason": { "type": "string" },
          "score": { "type": ["number", "null"] },
          "score_details": { "type": ["object", "null"] }
        }
      }
    }
  }
}
